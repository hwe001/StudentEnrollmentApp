<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StudentEnrollmentApp.Views.EnrollmentPage"
    Title="Enrollments">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Label
                Text="Enrollment Management"
                FontSize="28"
                HorizontalOptions="Center"/>

            <Entry
                x:Name="studentIdEntry"
                Placeholder="Student ID"
                Keyboard="Numeric"/>

            <Entry
                x:Name="courseCodeEntry"
                Placeholder="Course Code"/>

            <Button
                Text="Enroll Student"
                Clicked="OnEnrollClicked"/>

            <Button
                Text="Load Enrollments"
                Clicked="OnLoadEnrollmentsClicked"/>

            <CollectionView
                x:Name="enrollmentsCollectionView">

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border
                            Stroke="Gray"
                            StrokeThickness="1"
                            Padding="10"
                            Margin="0,5">

                            <VerticalStackLayout>

                                <Label
                                    Text="{Binding EnrollmentId}"
                                    FontAttributes="Bold"/>

                                <Label
                                    Text="{Binding StudentId}"/>

                                <Label
                                    Text="{Binding CourseCode}"/>

                                <Label
                                    Text="{Binding EnrollmentDate}"/>

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>