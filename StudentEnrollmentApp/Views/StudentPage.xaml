<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StudentEnrollmentApp.Views.StudentPage"
    Title="Students">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Label
                Text="Student Management"
                FontSize="28"
                HorizontalOptions="Center"/>

            <Entry
                x:Name="nameEntry"
                Placeholder="Student Name"/>

            <Entry
                x:Name="emailEntry"
                Placeholder="Email"
                Keyboard="Email"/>

            <Button
                Text="Add Student"
                Clicked="OnAddStudentClicked"/>

            <Button
                Text="Load Students"
                Clicked="OnLoadStudentsClicked"/>

            <CollectionView
                x:Name="studentsCollectionView">

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border
                            Stroke="Gray"
                            StrokeThickness="1"
                            Padding="10"
                            Margin="0,5">

                            <VerticalStackLayout>

                                <Label
                                    Text="{Binding StudentId}"
                                    FontAttributes="Bold"/>

                                <Label
                                    Text="{Binding Name}"/>

                                <Label
                                    Text="{Binding Email}"/>

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>