<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StudentEnrollmentApp.Views.CoursePage"
    Title="Courses">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Label
                Text="Course Management"
                FontSize="28"
                HorizontalOptions="Center"/>

            <Entry
                x:Name="courseCodeEntry"
                Placeholder="Course Code (CS101)"/>

            <Entry
                x:Name="courseNameEntry"
                Placeholder="Course Name"/>

            <Entry
                x:Name="creditsEntry"
                Placeholder="Credits"
                Keyboard="Numeric"/>

            <Button
                Text="Add Course"
                Clicked="OnAddCourseClicked"/>

            <Button
                Text="Load Courses"
                Clicked="OnLoadCoursesClicked"/>

            <CollectionView
                x:Name="coursesCollectionView">

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border
                            Stroke="Gray"
                            StrokeThickness="1"
                            Padding="10"
                            Margin="0,5">

                            <VerticalStackLayout>

                                <Label
                                    Text="{Binding CourseCode}"
                                    FontAttributes="Bold"/>

                                <Label
                                    Text="{Binding CourseName}"/>

                                <Label
                                    Text="{Binding Credits}"/>

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>